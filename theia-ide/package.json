{
  "private": true,
  "name": "aiterminal-theia",
  "version": "0.1.0",
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "AiTerminal IDE",
        "preferences": {
          "workbench.colorTheme": "Default Dark Modern"
        }
      }
    },
    "backend": {
      "config": {
        "startupTimeout": -1
      }
    }
  },
  "dependencies": {
    "@theia/core": "latest",
    "@theia/editor": "latest",
    "@theia/filesystem": "latest",
    "@theia/markers": "latest",
    "@theia/messages": "latest",
    "@theia/monaco": "latest",
    "@theia/navigator": "latest",
    "@theia/outline-view": "latest",
    "@theia/preferences": "latest",
    "@theia/process": "latest",
    "@theia/search-in-workspace": "latest",
    "@theia/terminal": "latest",
    "@theia/workspace": "latest",
    "@theia/plugin-ext": "latest",
    "@theia/plugin-ext-vscode": "latest",
    "@theia/scm": "latest",
    "@theia/scm-extra": "latest"
  },
  "devDependencies": {
    "@theia/cli": "latest"
  },
  "scripts": {
    "prepare": "theia build --mode production",
    "start": "theia start --port 3100 --hostname localhost",
    "build": "theia build --mode production"
  }
}
